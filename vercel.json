{
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/trainer",
      "destination": "/index.html"
    },
    {
      "source": "/integrated-task",
      "destination": "/integrated-physical-cognitive-task.html"
    },
    {
      "source": "/dual-task",
      "destination": "/integrated-physical-cognitive-task.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
